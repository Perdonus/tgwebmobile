<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.TGWeb.Settings.HeroCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mod_downloads_title"
                android:textAppearance="@style/TextAppearance.TGWeb.Settings.Eyebrow" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/downloads_title"
                android:textAppearance="@style/TextAppearance.TGWeb.Settings.HeroTitle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/downloads_overview_body"
                android:textAppearance="@style/TextAppearance.TGWeb.Settings.HeroBody" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/downloadsRefreshButton"
                style="@style/Widget.TGWeb.Settings.Button.Tonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/downloads_refresh" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.TGWeb.Settings.Card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="22dp"
            android:paddingEnd="22dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/downloads_library_title"
                android:textAppearance="@style/TextAppearance.TGWeb.Settings.SectionTitle" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="14dp"
                android:layout_weight="1">

                <ListView
                    android:id="@+id/downloadsList"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="10dp"
                    android:scrollbarStyle="outsideInset" />

                <TextView
                    android:id="@+id/downloadsEmptyText"
                    style="@style/Widget.TGWeb.Settings.ListEmptyText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/downloads_empty"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
