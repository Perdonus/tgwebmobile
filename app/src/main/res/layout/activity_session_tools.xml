<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TGWeb.Settings.HeroCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mod_session_tools_title"
                    android:textAppearance="@style/TextAppearance.TGWeb.Settings.Eyebrow" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/session_tools_title"
                    android:textAppearance="@style/TextAppearance.TGWeb.Settings.HeroTitle" />

                <TextView
                    android:id="@+id/sessionToolsDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/session_tools_description"
                    android:textAppearance="@style/TextAppearance.TGWeb.Settings.HeroBody" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TGWeb.Settings.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/session_tools_import_title"
                    android:textAppearance="@style/TextAppearance.TGWeb.Settings.SectionTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/mod_session_tools_summary"
                    android:textAppearance="@style/TextAppearance.TGWeb.Settings.SectionBody" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/importSessionButton"
                    style="@style/Widget.TGWeb.Settings.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/session_tools_import_session" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/importTdataButton"
                    style="@style/Widget.TGWeb.Settings.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/session_tools_import_tdata" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TGWeb.Settings.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/session_tools_export_title"
                    android:textAppearance="@style/TextAppearance.TGWeb.Settings.SectionTitle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/exportTelethonButton"
                    style="@style/Widget.TGWeb.Settings.Button.Tonal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/session_tools_export_telethon" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/exportPyrogramButton"
                    style="@style/Widget.TGWeb.Settings.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/session_tools_export_pyrogram" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/exportTdataButton"
                    style="@style/Widget.TGWeb.Settings.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/session_tools_export_tdata" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.TGWeb.Settings.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/session_tools_status_title"
                    android:textAppearance="@style/TextAppearance.TGWeb.Settings.SectionTitle" />

                <TextView
                    android:id="@+id/sessionStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/session_tools_idle"
                    android:textAppearance="@style/TextAppearance.TGWeb.Settings.Status" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
